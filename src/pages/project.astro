---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
---

<BaseLayout title="Projects">
  <MainCard
    title="项目"
    description="正在开发中的项目和想法。"
    textOverlay="项目"
    infoIcon="lucide:code-2"
    image="/image/background/project.webp"
    extraClasses="hero-cute-anime"
  >
    <div class="space-y-8">
      
      <!-- ========== FPGA AD936x SDR 项目 (2025-05-12) ========== -->
      <article class="card bg-base-200 overflow-hidden hover:shadow-xl transition-shadow group">
          <div class="md:flex">
            <figure class="md:w-64 md:flex-shrink-0 p-3 sakamoto-card-figure text-primary">
              <div class="sakamoto-img-wrapper">
                <img 
                  src="/image/project/fpga_ad936x 25-5-12/2D_PCB_Top_img.webp" 
                  alt="FPGA AD936x SDR" 
                  class="w-full h-48 md:h-full object-cover"
                  loading="eager"
                />
              </div>
            </figure>

            <div class="p-6 flex-1">
              <div class="flex items-start gap-3 mb-3">
                <div class="badge badge-primary">硬件设计</div>
                <div class="badge badge-outline">进行中</div>
                <div class="text-sm text-base-content/60">2025-05-12</div>
              </div>

              <h3 class="text-2xl font-bold mb-3 flex items-center gap-2">
                <Icon name="lucide:cpu" class="w-6 h-6 text-primary" />
                FPGA AD936x SDR 开发板
              </h3>

              <p class="text-base-content/70 mb-4">
                基于 Zynq7020 SoC 和 AD9361 射频芯片的软件定义无线电（SDR）开发板项目。
              </p>

              <div class="space-y-2 text-sm text-base-content/80 mb-4">
                <div class="flex items-center gap-2">
                  <Icon name="lucide:cpu" class="w-4 h-4 text-primary" />
                  <span>Xilinx Zynq7020 SoC（双核 ARM Cortex-A9 + FPGA）</span>
                </div>
                <div class="flex items-center gap-2">
                  <Icon name="lucide:radio-tower" class="w-4 h-4 text-primary" />
                  <span>AD9361 射频芯片（70MHz - 6GHz 带宽）</span>
                </div>
                <div class="flex items-center gap-2">
                  <Icon name="lucide:cable" class="w-4 h-4 text-primary" />
                  <span>千兆以太网、USB OTG、MIPI CSI 摄像头</span>
                </div>
              </div>

              <div class="flex gap-2">
                <a href="/blog/fpga-ad936x-sdr" class="btn btn-sm btn-primary">查看设计详情</a>
              </div>
            </div>
          </div>
        </article>

      <!-- ========== BD2 效果器 (2025-02-03) ========== -->
          <article class="card bg-base-200 overflow-hidden hover:shadow-xl transition-shadow group">
            <div class="md:flex">
              <figure class="md:w-64 md:flex-shrink-0 p-3 sakamoto-card-figure text-accent">
                <div class="sakamoto-img-wrapper">
                  <img 
                    src="/image/project/BD2 25-2-3/cover.webp" 
                    alt="BD2驱动板" 
                    class="w-full h-48 md:h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </figure>

              <div class="p-6 flex-1">
                <div class="flex items-start gap-3 mb-3">
                  <div class="badge badge-accent">音频效果器</div>
                  <div class="badge badge-success">已完成</div>
                  <div class="text-sm text-base-content/60">2025-02-03</div>
                </div>

                <h3 class="text-2xl font-bold mb-3 flex items-center gap-2">
                  <Icon name="lucide:music" class="w-6 h-6 text-accent" />
                  BD2 效果器
                </h3>

                <p class="text-base-content/70 mb-4">
                  <!-- 📝 待填写：项目介绍 -->
                  <span class="italic text-base-content/50">待添加项目介绍...</span>
                </p>

                <div class="flex gap-2">
                  <a href="/blog/bd2-effect-pedal" class="btn btn-sm btn-accent">查看详情</a>
                </div>
              </div>
            </div>
          </article>

      <!-- ========== 智能车比赛 (2025-01) ========== -->
      <section>
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-2xl font-bold">智能车比赛</h2>
          <div class="badge badge-lg badge-secondary">2025年1月</div>
        </div>

        <div class="space-y-4">

          <!-- 逐飞驱动板 (2025-01-13) -->
          <article class="card bg-base-200 overflow-hidden hover:shadow-xl transition-shadow group">
            <div class="md:flex">
              <figure class="md:w-64 md:flex-shrink-0 p-3 sakamoto-card-figure text-secondary">
                <div class="sakamoto-img-wrapper">
                  <img 
                    src="/image/project/zhufei_driver 25-1-13/cover.webp" 
                    alt="逐飞驱动板" 
                    class="w-full h-48 md:h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </figure>

              <div class="p-6 flex-1">
                <div class="flex items-start gap-3 mb-3">
                  <div class="badge badge-secondary">智能车</div>
                  <div class="badge badge-success">已完成</div>
                  <div class="text-sm text-base-content/60">2025-01-13</div>
                </div>

                <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
                  <Icon name="lucide:zap" class="w-5 h-5 text-secondary" />
                  逐飞驱动板
                </h3>

                <p class="text-base-content/70 mb-4">
                  <!-- 📝 待填写：项目介绍 -->
                  <span class="italic text-base-content/50">待添加项目介绍...</span>
                </p>

                <div class="flex gap-2">
                  <a href="/blog/zhufei-driver-board" class="btn btn-sm btn-secondary">查看详情</a>
                </div>
              </div>
            </div>
          </article>

          <!-- 舵机驱动板 (2025-01-11) -->
          <article class="card bg-base-200 overflow-hidden hover:shadow-xl transition-shadow group">
            <div class="md:flex">
              <figure class="md:w-64 md:flex-shrink-0 p-3 sakamoto-card-figure text-secondary">
                <div class="sakamoto-img-wrapper">
                  <img 
                    src="/image/project/servo_driver 25-1-11/cover.webp" 
                    alt="舵机驱动板" 
                    class="w-full h-48 md:h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </figure>

              <div class="p-6 flex-1">
                <div class="flex items-start gap-3 mb-3">
                  <div class="badge badge-secondary">智能车</div>
                  <div class="badge badge-success">已完成</div>
                  <div class="text-sm text-base-content/60">2025-01-11</div>
                </div>

                <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
                  <Icon name="lucide:move" class="w-5 h-5 text-secondary" />
                  舵机驱动板
                </h3>

                <p class="text-base-content/70 mb-4">
                  <!-- 📝 待填写：项目介绍 -->
                  <span class="italic text-base-content/50">待添加项目介绍...</span>
                </p>

                <div class="flex gap-2">
                  <a href="/blog/servo-driver-board" class="btn btn-sm btn-secondary">查看详情</a>
                </div>
              </div>
            </div>
          </article>

          <!-- 扩展板 (2025-01-11) -->
          <article class="card bg-base-200 overflow-hidden hover:shadow-xl transition-shadow group">
            <div class="md:flex">
              <figure class="md:w-64 md:flex-shrink-0 p-3 sakamoto-card-figure text-secondary">
                <div class="sakamoto-img-wrapper">
                  <img 
                    src="/image/project/Expanding board 25-1-11/cover.webp" 
                    alt="扩展板" 
                    class="w-full h-48 md:h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </figure>

              <div class="p-6 flex-1">
                <div class="flex items-start gap-3 mb-3">
                  <div class="badge badge-secondary">智能车</div>
                  <div class="badge badge-success">已完成</div>
                  <div class="text-sm text-base-content/60">2025-01-11</div>
                </div>

                <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
                  <Icon name="lucide:boxes" class="w-5 h-5 text-secondary" />
                  扩展板
                </h3>

                <p class="text-base-content/70 mb-4">
                  <!-- 📝 待填写：项目介绍 -->
                  <span class="italic text-base-content/50">待添加项目介绍...</span>
                </p>

                <div class="flex gap-2">
                  <a href="/blog/expansion-board" class="btn btn-sm btn-secondary">查看详情</a>
                </div>
              </div>
            </div>
          </article>

        </div>
      </section>

      <!-- ========== BLDC 无刷电机驱动 (2024-11-23) ========== -->
          <article class="card bg-base-200 overflow-hidden hover:shadow-xl transition-shadow group">
            <div class="md:flex">
              <figure class="md:w-64 md:flex-shrink-0 p-3 sakamoto-card-figure text-info">
                <div class="sakamoto-img-wrapper">
                  <img 
                    src="/image/project/BLDC driver 24-11-23/cover.webp" 
                    alt="BLDC无刷电机驱动" 
                    class="w-full h-48 md:h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </figure>

              <div class="p-6 flex-1">
                <div class="flex items-start gap-3 mb-3">
                  <div class="badge badge-info">电机驱动</div>
                  <div class="badge badge-success">已完成</div>
                  <div class="text-sm text-base-content/60">2024-11-23</div>
                </div>

                <h3 class="text-2xl font-bold mb-3 flex items-center gap-2">
                  <Icon name="lucide:rotate-3d" class="w-6 h-6 text-info" />
                  BLDC 无刷电机驱动
                </h3>

                <p class="text-base-content/70 mb-4">
                  <!-- 📝 待填写：项目介绍 -->
                  <span class="italic text-base-content/50">待添加项目介绍...</span>
                </p>

                <div class="flex gap-2">
                  <a href="/blog/bldc-motor-driver" class="btn btn-sm btn-info">查看详情</a>
                </div>
              </div>
            </div>
          </article>

      <!-- GitHub 链接 -->
      <div class="text-center pt-8">
        <a
          href="https://github.com/AAkoi"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline gap-2"
        >
          <Icon name="lucide:github" class="w-5 h-5" />
          <span>查看更多项目</span>
        </a>
      </div>
      </div>
  </MainCard>
</BaseLayout>
